{
  "name": "leagueproxy",
  "version": "2.0.0",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "node scripts/build-frontend.js",
    "build:dev": "cross-env PROXCHAT_DEV_BUILD=1 node scripts/build-frontend.js",
    "build:prod": "cross-env PROXCHAT_DEV_BUILD=0 node scripts/build-frontend.js",
    "build:release": "cross-env PROXCHAT_DEV_BUILD=0 node scripts/build-frontend.js",
    "build:server": "cross-env PROXCHAT_DEV_BUILD=0 node scripts/build-frontend-server.js",
    "build:server:dev": "cross-env PROXCHAT_DEV_BUILD=1 node scripts/build-frontend-server.js",
    "generate:icons": "node scripts/generate-icons.mjs",
    "test": "node --experimental-strip-types --test src/overlay/resize-helpers.test.ts src/services/audio-volume.test.ts src/services/audio-transmit.test.ts src/services/tracking-helpers.test.ts src/services/template-match-math.test.ts src/services/audio-worklet/vad-math.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "description": "Proximity voice chat for League of Legends custom games",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sandrochkhaidzee/LeagueCustomProxy.git"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@shiguredo/rnnoise-wasm": "^2025.1.5",
    "@tauri-apps/api": "^2.10.1",
    "onnxruntime-web": "^1.24.3"
  }
}
