{
  "$schema": "https://raw.githubusercontent.com/nickvdyck/tauri-settings-schema/refs/heads/main/schemas/2.1.0/schema.json",
  "productName": "LeagueProxy Server",
  "version": "2.0.0",
  "identifier": "com.leagueproxy.server",
  "build": {
    "frontendDist": "../dist-server",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "",
    "beforeDevCommand": "node scripts/build-frontend-server.js"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "LeagueProxy Host",
        "width": 260,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "url": "overlay/overlay.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons-server/32x32.png",
      "icons-server/128x128.png",
      "icons-server/icon.ico"
    ]
  }
}
